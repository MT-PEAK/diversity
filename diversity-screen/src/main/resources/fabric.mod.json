{
    "schemaVersion": 1,
    "id": "diversity-screen",
    "version": "${version}",
    "name": "Diversity Screen",
    "description": "Screen module of the Diversity API.",
    "license": "Unlicense",
    "depends": {
        "fabricloader": ">=${loader_version}",
        "minecraft": "~${minecraft_version}",
        "java": ">=21",
        "diversity-core": "${version}"
    },
    "entrypoints": {
        "main": [
            "com.peak.diversityScreen.impl.DiversityScreen"
        ],
        "client": [
            "com.peak.diversityScreen.impl.DiversityScreenClient"
        ],
        "fabric-datagen": [
            "com.peak.diversityScreen.data.DiversityScreenDataGenerator"
        ]
    },
    "custom": {
        "modmenu": {
            "badges": [ "library" ],
            "parent": {
                "id": "diversity",
                "name": "Diversity",
                "description": "A multi-module Fabric API.",
                "badges": [ "library" ]
            }
        }
    }
}
